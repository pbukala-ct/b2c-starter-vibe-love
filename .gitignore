# ─── Environment files — NEVER commit these ──────────────────────────────────
# Matches .env in any directory (site/.env, tools/.env, etc.)
.env
.env.local
.env.*.local
.env.production
.env.test
# Belt-and-suspenders: explicit paths in case of git add --force
site/.env
tools/.env

# ─── Dependencies ─────────────────────────────────────────────────────────────
**/node_modules/

# ─── Next.js ──────────────────────────────────────────────────────────────────
site/.next/
site/out/
site/.vercel

# ─── Build artifacts ──────────────────────────────────────────────────────────
site/build/
*.tsbuildinfo
site/next-env.d.ts

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
*.pem

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# Local Netlify folder
.netlify
test/playwright-report/
test/test-results/

# ─── OpenSpec (local change proposals) ───────────────────────────────────────
openspec/
